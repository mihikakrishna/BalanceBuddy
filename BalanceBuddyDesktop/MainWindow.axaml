<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BalanceBuddyDesktop.MainWindow"
        Title="BalanceBuddyDesktop"
        Background="#E8ECDD">

	<Window.Styles>
		<Style Selector="Button">
			<Setter Property="Background" Value="#80D465"/>
			<Setter Property="BorderBrush" Value="#4DA557"/>
			<Setter Property="BorderThickness" Value="2"/>
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="Padding" Value="10"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="FontSize" Value="16"/>
		</Style>
	</Window.Styles>

	<ContentControl x:Name="MainContent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

</Window>
